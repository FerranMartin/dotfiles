# This is Git's per-user configuration file.
[user]
	name = Ferran Martín
	email = ferranmatin@gmail.com
[alias]
    co = checkout
    ci = commit
    st = status
    br = branch
    branch-name = "!git rev-parse --abbrev-ref HEAD"
    publish = "!git push -u origin $(git branch-name)"
[core]
    excludesfile = ~/.gitignore_global